# IA²E V2 - Hybrid Intelligence Configuration
# ==========================================

# Select your preferred premium narrator: "claude", "gemini", "openai"
PREMIUM_LLM_PROVIDER=claude

# API Keys (Get them at their respective providers)
ANTHROPIC_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Local Fallback (Set true if you want to use Ollama when APIs fail)
USE_LOCAL_FALLBACK=true
LOCAL_OLLAMA_MODEL=qwen2.5:14b

# Cache Narrative responses (Saves tokens/cost)
ENABLE_NARRATIVE_CACHE=true
