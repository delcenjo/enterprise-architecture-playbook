{
    "AML_LEY_10_2010": {
        "name": "AML/PBC Ley 10/2010 (España)",
        "type": "AML",
        "level": "National",
        "requirements": [
            "Formal client identification (KYC)",
            "Ultimate Beneficial Owner (UBO) identification",
            "Real-time transaction monitoring",
            "Suspicious Activity Reporting (SAR/ROS) to SEPBLAC",
            "10-year immutable document retention"
        ],
        "metrics": [
            "kyc_completion_rate",
            "transaction_monitoring_latency",
            "alert_false_positive_ratio"
        ],
        "risk_associated": "High",
        "relationships": {
            "complements": [
                "GDPR",
                "PSD2",
                "MiCA"
            ],
            "conflicts": [
                "GDPR_Minimization"
            ]
        }
    },
